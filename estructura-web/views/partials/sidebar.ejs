<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>sidebar</title>
</head>
<body>
   <aside class="w-64 h-screen fixed left-0 top-0 bg-gray-900 text-white flex flex-col p-4">
            <h2 class="text-xl font-bold mb-6">PawLink</h2>

            <nav class="flex flex-col gap-3">

                <a href="/index" class="px-3 py-2 rounded-lg transition
           <%= active === 'inicio' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                    Inicio
                </a>

                <a href="/vistaEleccion" class="px-3 py-2 rounded-lg transition
           <%= active === 'adopciones' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                    Adopciones
                </a>

                <a href="/perfil" class="px-3 py-2 rounded-lg transition
           <%= active === 'perfil' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                    Perfil
                </a>

                <a href="/#" class="px-3 py-2 rounded-lg transition
           <%= active === 'procesos' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                    Procesos
                </a>

                <a href="/contacto" class="px-3 py-2 rounded-lg transition
           <%= active === 'contacto' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                    Contacto
                </a>

                <%if(userData.admin) {%>
                    <a href="/adm" class="px-3 py-2 rounded-lg transition
           <%= active === 'administracion' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Administración
                    </a>

                    <%}%>

                        <a href="/logout" class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 transition mt-auto">
                            Cerrar sesión
                        </a>

            </nav>
        </aside>
</body>
</html>