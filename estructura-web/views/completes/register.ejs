<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Registro</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    @layer utilities {
      @keyframes float {
        0% {
          transform: translateY(0);
          opacity: 0.6;
        }

        50% {
          transform: translateY(-35px);
          opacity: 1;
        }

        100% {
          transform: translateY(0);
          opacity: 0.6;
        }
      }

      .bubble {
        animation: float 6s ease-in-out infinite;
      }
    }
  </style>
</head>

<body
  class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#E5531C] to-[#CCE2ED] relative overflow-hidden">
  <!-- Arriba izquierda -->
  <div class="absolute top-5 left-5 w-48 h-48 bg-[#E5531C]/60 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba centro -->
  <div class="absolute top-10 left-1/2 w-40 h-40 bg-[#F7A97B]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba derecha -->
  <div class="absolute top-1/4 right-10 w-44 h-44 bg-[#CCE2ED]/60 rounded-full blur-3xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro izquierda -->
  <div class="absolute top-1/2 left-10 w-36 h-36 bg-[#FFE3C2]/70 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro derecha -->
  <div class="absolute top-1/2 right-1/4 w-32 h-32 bg-[#E5531C]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo izquierda -->
  <div class="absolute bottom-10 left-1/4 w-52 h-52 bg-[#E5531C]/50 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo centro -->
  <div class="absolute bottom-5 left-1/2 w-28 h-28 bg-[#F7A97B]/60 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <div class="absolute top-5 left-5 w-48 h-48 bg-[#E5531C]/60 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba centro -->
  <div class="absolute top-10 left-1/2 w-40 h-40 bg-[#F7A97B]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba derecha -->
  <div class="absolute top-1/4 right-10 w-44 h-44 bg-[#CCE2ED]/60 rounded-full blur-3xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro izquierda -->
  <div class="absolute top-1/2 left-10 w-36 h-36 bg-[#FFE3C2]/70 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro derecha -->
  <div class="absolute top-1/2 right-1/4 w-32 h-32 bg-[#E5531C]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo izquierda -->
  <div class="absolute bottom-10 left-1/4 w-52 h-52 bg-[#E5531C]/50 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo centro -->
  <div class="absolute bottom-5 left-1/2 w-28 h-28 bg-[#F7A97B]/60 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <div class="bg-white/20 backdrop-blur-xl p-10 rounded-2xl shadow-2xl w-80 text-white relative z-10">

    <h1 class="text-3xl font-bold mb-6 text-center">Registro de usuario</h1>

    <form action="/register" method="POST" class="space-y-4">
      <label class="block mb-1">Nombre:</label>
      <input type="text" name="nombre" required
        class="w-full p-3 rounded-lg bg-white/30 placeholder-white/70 focus:outline-none">

      <label class="block mb-1">Email:</label>
      <input type="email" name="email" required
        class="w-full p-3 rounded-lg bg-white/30 placeholder-white/70 focus:outline-none">

      <label class="block mb-1">Contraseña:</label>
      <input type="password" name="password" required
        class="w-full p-3 rounded-lg bg-white/30 placeholder-white/70 focus:outline-none">

      <button type="submit"
        class="w-full bg-white text-indigo-700 font-semibold py-3 rounded-lg hover:bg-gray-200 transition">Registrarse</button>

<a href="/" class="block mx-auto w-fit px-6 py-3 bg-white text-indigo-700 font-semibold rounded-lg shadow-sm hover:bg-gray-100 transition">
  Volver atrás
</a>


      <% if(errorL){ %>
        <h3 id="error" style="color: red;">
          <%= errorL.mensaje %>
        </h3>
        <% } %>
    </form>
  </div>
</body>

</html>