<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración</title>
    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body>
    <%if(userData) { %>
        <%if(userData.admin) { %>
            <%- include("../partials/sidebar") %>
            <main class="ml-64 p-6">

                <nav class="bg-white shadow px-6 py-4 flex gap-6 text-gray-700 font-medium">
                    <a href="#usuarios" class="hover:text-blue-600">Usuarios</a>
                    <a href="#animales" class="hover:text-blue-600">Animales</a>
                    <a href="#" class="hover:text-blue-600">Protectoras</a>
                    <a href="#" class="hover:text-blue-600">Solicitudes</a>
                    <a href="#" class="hover:text-blue-600">Seguimientos</a>
                </nav>

                <br>
                <table class="border border-gray-300 rounded-lg border-separate border-spacing-0 w-full" id="usuarios">
                    <tr>
                        <th colspan="5" class="text-center py-2 bg-gray-100">
                            GESTIÓN DE USUARIOS
                        </th>
                    </tr>
                    <tr class="bg-gray-50">
                        <th class="border">ID</th>
                        <th class="border">Usuario</th>
                        <th class="border">Email</th>
                        <th class="border">Fecha de registro</th>
                        <th class="border">Acciones</th>
                    </tr>
                    <tbody class="text-center">
                        <% if(usuarios && usuarios.length> 0) { %>
                            <% usuarios.forEach(usuario=> { %>
                                <tr class="p-20">
                                    <td class="border">
                                        <%= usuario.id %>
                                    </td>
                                    <td class="border">
                                        <%= usuario.username %>
                                    </td>
                                    <td class="border">
                                        <%= usuario.email %>
                                    </td>
                                    <td class="border">
                                        <%= new Date(usuario.fecha_registro).toLocaleDateString("es-ES") %>
                                            <%= new Date(usuario.fecha_registro).toLocaleTimeString("es-ES", {
                                                hour: "2-digit" , minute: "2-digit" }) %>
                                    </td>
                                    <td class="border">
                                        <!--Boton eliminar-->
                                        <button type="button" onclick="deleteUser('<%= usuario.id %>')"
                                            class="text-red-600 hover:text-red-800">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="1.5" stroke="currentColor" class="size-6">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                            </svg>
                                        </button>

                                        <!--Boton editar-->
                                        <button type="button"
                                            onclick="openEditModal('<%= usuario.id %>', '<%= usuario.username %>', '<%= usuario.email %>', '<%= usuario.admin %>', '<%= usuario.fecha_registro %>')"
                                            class="text-blue-600 hover:text-blue-800">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="1.5" stroke="currentColor" class="size-6">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                            </svg>

                                        </button>

                                    </td>

                                </tr>

                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="border">No hay usuarios registrados</td>
                                        </tr>
                                        <% } %>
                                            <tr>
                                                <td colspan="5" class="text-center py-2">
                                                    <button onclick="openNewModal()" class="w-full max-w-xs mx-auto flex items-center justify-center gap-2 
                                                        bg-blue-600 hover:bg-blue-700 text-white font-medium 
                                                        py-2 rounded transition">
                                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                                                            viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                                            class="w-5 h-5">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                                        </svg>
                                                        Añadir usuario
                                                    </button>
                                                </td>
                                            </tr>

                    </tbody>
                </table>
                <br>
                <!--TABLA ANIMALES-->
                <table class="border border-gray-300 rounded-lg border-separate border-spacing-0 w-full" id="#animales">
                    <tr>
                        <th colspan="16" class="text-center py-2">
                            GESTIÓN DE ANIMALES
                        </th>
                    </tr>
                    <tr>
                        <th class="border">ID</th>
                        <th class="border">Nombre</th>
                        <th class="border">Chip</th>
                        <th class="border">Especie</th>
                        <th class="border">Raza</th>
                        <th class="border">Sexo</th>
                        <th class="border">Fecha de nacimiento</th>
                        <th class="border">Color</th>
                        <th class="border">Pelaje</th>
                        <th class="border">Vacunas</th>
                        <th class="border">Esterilizado</th>
                        <th class="border">Desparasitado</th>
                        <th class="border">Tamaño</th>
                        <th class="border">Nivel de energia</th>
                        <th class="border">Disponible</th>
                        <th class="border">Acciones</th>


                    </tr>
                    <tbody>

                        <td class="border">
                            <!--Boton eliminar-->
                            <button type="button" class="text-red-600 hover:text-red-800">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                </svg>
                            </button>

                            <!--Boton editar-->
                            <button type="button" class="text-blue-600 hover:text-blue-800">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                </svg>

                            </button>

                        </td>

                    </tbody>
                </table>


                <% }else{ %>
                    <div
                        class="w-full max-w-lg mx-auto mt-16 bg-white shadow-lg rounded-xl p-8 text-center border border-gray-200">
                        <h2 class="text-2xl font-bold text-gray-800 mb-3">
                            ¡Ups! Parece que no tienes permisos para estar aquí.
                        </h2>

                        <p class="text-gray-600 mb-6">
                            Para acceder a esta sección necesitas permisos.
                            No te preocupes, te llevamos de vuelta a la página principal.
                        </p>

                        <a href="/index"
                            class="inline-block bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:bg-blue-700 transition">
                            Volver al inicio
                        </a>
                    </div>
                    <%} %>

                        <%}else{%>

                            <div
                                class="w-full max-w-lg mx-auto mt-16 bg-white shadow-lg rounded-xl p-8 text-center border border-gray-200">
                                <h2 class="text-2xl font-bold text-gray-800 mb-3">
                                    ¡Ups! Parece que no estás logueado
                                </h2>

                                <p class="text-gray-600 mb-6">
                                    Para acceder a esta sección necesitas iniciar sesión.
                                    No te preocupes, te llevamos de vuelta a la página principal.
                                </p>

                                <a href="/"
                                    class="inline-block bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:bg-blue-700 transition">
                                    Volver al inicio
                                </a>
                            </div>

                            <%}%>
            </main>


            <!--MODAL PARA EDITAR USUARIOS-->
            <div id="editUserModal"
                class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">
                <div class="bg-white p-6 rounded shadow-lg w-96">
                    <h2 class="text-xl font-bold mb-4">Editar usuario</h2>

                    <form id="editUForm">
                        <input type="hidden" id="editId">

                        <label class="block mb-2">Nombre</label>
                        <input id="editUName" class="w-full border p-2 mb-3">

                        <label class="block mb-2">Email</label>
                        <input id="editUEmail" class="w-full border p-2 mb-3">

                        <label class="block mb-2">Admin</label>
                        <select id="editUAdmin" class="w-full border p-2 mb-3">
                            <option value="false">No</option>
                            <option value="true">Sí</option>
                        </select>

                        <label class="block mb-2">Fecha de registro</label>
                        <input id="editUFecha" class="w-full border p-2 mb-3" disabled>

                        <div class="flex justify-end gap-3 mt-4">
                            <button type="button" onclick="closeEditModal()"
                                class="px-4 py-2 bg-gray-300 rounded">Cancelar</button>
                            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>

            <!--Modal PARA AÑADIR USUARIOS-->
            <div id="newUserModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">
                <div class="bg-white p-6 rounded shadow-lg w-96">
                    <h2 class="text-xl font-bold mb-4">Añadir nuevo usuario</h2>

                    <form id="newForm">
                        <input type="hidden" id="newId">

                        <label class="block mb-2">Nombre</label>
                        <input id="newName" class="w-full border p-2 mb-3">

                        <label class="block mb-2">Email</label>
                        <input id="newEmail" class="w-full border p-2 mb-3">

                        <label class="block mb-2">Contraseña</label>
                        <input id="newPassword" type="password" class="w-full border p-2 mb-3">

                        <label class="block mb-2">Admin</label>
                        <select id="newAdmin" class="w-full border p-2 mb-3">
                            <option value="false">No</option>
                            <option value="true">Sí</option>
                        </select>

                        <label class="block mb-2">Fecha de registro</label>
                        <input id="newFecha" class="w-full border p-2 mb-3" disabled>

                        <div class="flex justify-end gap-3 mt-4">
                            <button type="button" onclick="closeNewModal()"
                                class="px-4 py-2 bg-gray-300 rounded">Cancelar</button>
                            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Crear y
                                guardar</button>
                        </div>
                    </form>
                </div>
            </div>

            <script>
                //Borrar usuarios
                async function deleteUser(id) {
                    if (!confirm("¿Seguro que quieres eliminar este usuario?")) {
                        return;
                    }

                    const res = await fetch(`/adm/users/${id}`, {
                        method: "DELETE"
                    });

                    const data = await res.json();

                    //Si devuelve 200
                    if (data.ok) {
                        alert("Usuario eliminado correctamente");
                        location.reload();
                    } else {
                        alert("Error al eliminar usuario");
                    }
                }

                //Funcion para abrir modal de edicion de usuarios
                function openEditModal(id, name, email, admin, fecha) {
                    document.getElementById("editId").value = id;
                    document.getElementById("editUName").value = name;
                    document.getElementById("editUEmail").value = email;
                    document.getElementById("editUAdmin").value = admin;
                    document.getElementById("editUFecha").value = fecha;

                    document.getElementById("editUserModal").classList.remove("hidden");
                }

                function openNewModal() {
                    // Establecer la fecha actual
                    const now = new Date();
                    const fechaFormato = now.toLocaleDateString("es-ES") + " " +
                        now.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" });
                    document.getElementById("newFecha").value = fechaFormato;
                    document.getElementById("newUserModal").classList.remove("hidden");
                }

                function closeNewModal() {
                    document.getElementById("newUserModal").classList.add("hidden");
                    document.getElementById("newForm").reset();
                }

                //Cerrar modal de edicion
                function closeEditModal() {
                    document.getElementById("editUserModal").classList.add("hidden");
                }

                document.getElementById("editUForm").addEventListener("submit", async (e) => {
                    e.preventDefault();

                    const id = document.getElementById("editId").value;
                    const name = document.getElementById("editUName").value;
                    const email = document.getElementById("editUEmail").value;
                    const admin = document.getElementById("editUAdmin").value;

                    if (!name || !email) {
                        alert("El nombre y email son obligatorios");
                        return;
                    }

                    const res = await fetch(`/adm/users/${id}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ name, email, admin })
                    });

                    const data = await res.json();

                    if (data.ok) {
                        alert("Usuario actualizado correctamente");
                        location.reload();
                    } else {
                        alert("Error al actualizar usuario: " + (data.message || ""));
                    }
                });

                document.getElementById("newForm").addEventListener("submit", async (e) => {
                    e.preventDefault();

                    const name = document.getElementById("newName").value;
                    const email = document.getElementById("newEmail").value;
                    const password = document.getElementById("newPassword").value;
                    const admin = document.getElementById("newAdmin").value;

                    if (!name || !email || !password) {
                        alert("Por favor rellena todos los campos");
                        return;
                    }

                    const res = await fetch(`/adm/users`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ name, email, password, admin })
                    });

                    const data = await res.json();

                    if (data.ok) {
                        alert("Usuario creado correctamente");
                        closeNewModal();
                        location.reload();
                    } else {
                        alert("Error al crear usuario: " + (data.message || ""));
                    }
                });
            </script>

</body>

</html>