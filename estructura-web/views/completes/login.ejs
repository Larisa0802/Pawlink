<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PawZone — Iniciar Sesión</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    body { background: #E5531C; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeUp { animation: fadeUp 0.55s cubic-bezier(.22,1,.36,1) both; }
    .delay-1 { animation-delay: 0.08s; }
    .delay-2 { animation-delay: 0.16s; }
    .delay-3 { animation-delay: 0.24s; }

    @keyframes floatY {
      0%, 100% { transform: translateY(0px); }
      50%       { transform: translateY(-8px); }
    }
    .mascot { animation: floatY 4s ease-in-out infinite; }

    @keyframes driftPaw {
      0%   { transform: translateY(0) rotate(var(--r)); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { transform: translateY(-100vh) rotate(calc(var(--r) + 20deg)); opacity: 0; }
    }
    .paw-drift { animation: driftPaw var(--dur) linear var(--delay) infinite; }

    input:focus { outline: none; box-shadow: 0 0 0 2px #E5531C; }

    .btn-main { transition: transform 0.15s ease, box-shadow 0.15s ease; background: #E5531C; }
    .btn-main:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(229,83,28,0.35); }
    .btn-main:active { transform: translateY(0); box-shadow: none; }

    .tab-active   { border-bottom: 2px solid #000000; color: #000000; }
    .tab-inactive { border-bottom: 2px solid transparent; color: #9CA3AF; }

    .social-btn { border: 1px solid #DDCCE6; transition: border-color 0.15s, background 0.15s; }
    .social-btn:hover { border-color: #E5531C; background: #fff5f2; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center overflow-hidden relative">

  <!-- Huellitas flotantes -->
 <!-- Arriba izquierda -->
  <div class="absolute top-5 left-5 w-48 h-48 bg-[#E5531C]/60 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba centro -->
  <div class="absolute top-10 left-1/2 w-40 h-40 bg-[#F7A97B]/50 rounded-full blur-xl bubble"
    style="animation-duration: 8s;"></div>

  <!-- Arriba derecha -->
  <div class="absolute top-1/4 right-10 w-44 h-44 bg-[#CCE2ED]/60 rounded-full blur-3xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro izquierda -->
  <div class="absolute top-1/2 left-10 w-36 h-36 bg-[#FFE3C2]/70 rounded-full blur-xl bubble"
    style="animation-duration: 7s;"></div>

  <!-- Centro derecha -->
  <div class="absolute top-1/2 right-1/4 w-32 h-32 bg-[#E5531C]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo izquierda -->
  <div class="absolute bottom-10 left-1/4 w-52 h-52 bg-[#E5531C]/50 rounded-full blur-2xl bubble"
    style="animation-duration: 11s;"></div>

  <!-- Abajo centro -->
  <div class="absolute bottom-5 left-1/2 w-28 h-28 bg-[#F7A97B]/60 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <div class="absolute top-5 left-5 w-48 h-48 bg-[#E5531C]/60 rounded-full blur-2xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Arriba centro -->
  <div class="absolute top-10 left-1/2 w-40 h-40 bg-[#F7A97B]/50 rounded-full blur-xl bubble"
    style="animation-duration: 8s;"></div>

  <!-- Arriba derecha -->
  <div class="absolute top-1/4 right-10 w-44 h-44 bg-[#CCE2ED]/60 rounded-full blur-3xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Centro izquierda -->
  <div class="absolute top-1/2 left-10 w-36 h-36 bg-[#FFE3C2]/70 rounded-full blur-xl bubble"
    style="animation-duration: 7s;"></div>

  <!-- Centro derecha -->
  <div class="absolute top-1/2 right-1/4 w-32 h-32 bg-[#E5531C]/50 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>

  <!-- Abajo izquierda -->
  <div class="absolute bottom-10 left-1/4 w-52 h-52 bg-[#E5531C]/50 rounded-full blur-2xl bubble"
    style="animation-duration: 11s;"></div>

  <!-- Abajo centro -->
  <div class="absolute bottom-5 left-1/2 w-28 h-28 bg-[#F7A97B]/60 rounded-full blur-xl bubble"
    style="animation-duration: 5s;"></div>


  <!-- Card -->
  <div class="relative z-10 w-full max-w-4xl mx-4 flex rounded-3xl overflow-hidden shadow-2xl animate-fadeUp" style="background:#FFFFFF">

    <!-- ── Panel izquierdo ── -->
    <div class="hidden md:flex flex-col items-center justify-between w-2/5 text-white px-10 py-12" style="background-color:#CCE2ED22;">

      <!-- Logo -->
      <div class="self-start animate-fadeUp delay-1">
        <p class="text-xs tracking-[0.25em] uppercase mb-1" style="color:#E5531C;opacity:0.7"><span class="text-L font-bold">BIENVENIDO</span> a la <span class="text-xl font-bold">PAWZONE</span></p>
      </div>

      <!-- Mascota flotando -->
      <div class="mascot animate-fadeUp delay-2">

       <img id="svgCat"
  src="/img/cat.png"
  alt="Gato PawZone"
  class="mascot"
  style="width: 148px; height: 170px; object-fit: contain;" />

<img id="svgDog"
  src="/img/dog.png"
  alt="Perro PawZone"
  class="mascot"
  style="width: 148px; height: 170px; object-fit: contain; display: none;" />
      </div>

      <!-- Toggle + tagline -->
      <div class="self-stretch animate-fadeUp delay-3">
        <div class="flex gap-2 mb-5" style="background:rgba(255, 255, 255, 0.238);border-radius:12px;padding:4px">
          <button onclick="setMascot('cat')" id="btnCat"
            class="flex-1 py-2 rounded-lg text-sm font-medium transition-all bg-orange-500"
            style="background:#E5531C;color:rgb(0, 0, 0)">
            Gato
          </button>
          <button onclick="setMascot('dog')" id="btnDog"
            class="flex-1 py-2 rounded-lg text-sm font-medium transition-all"
            style="color:rgba(0, 0, 0, 0.4)">
            Perro
          </button>
        </div>
        <p id="tagline" class="text-xs leading-relaxed tracking-wide" style="color:#E5531C;opacity:0.65">
          "Los gatos no necesitan motivo<br>para quererte."
        </p>
      </div>
    </div>

    <!-- ── Panel derecho — formulario ── -->
    <div class="flex-1 px-10 py-12 flex flex-col justify-center" style="background:#FFFFFF">

      <!-- Tabs -->
      <div class="flex gap-8 mb-10 animate-fadeUp delay-1">
        <button onclick="switchTab('login')" id="tabLogin"
          class="tab-active pb-2 text-sm font-semibold tracking-wide transition-all">
          Iniciar sesión
        </button>

         <a href="register"
          class="tab-inactive pb-2 text-sm font-semibold tracking-wide transition-all">
          Crear cuenta
      </a>
      </div>

      <!-- LOGIN -->
      <div id="viewLogin" class="space-y-5 animate-fadeUp delay-2">
            <form action="/login" method="POST" class="space-y-4">

        <div>
          <label class="block text-[10px] font-semibold tracking-[0.2em] uppercase mb-2" style="color:#9CA3AF">Email</label>
          <input type="text" name="email" placeholder="hola@pawzone.com" required
            class="w-full rounded-xl px-4 py-3 text-sm transition"
            style="border:1px solid #DDCCE6;background:#CCE2ED22;color:#000"/>
        </div>
        <div>
          <div class="flex justify-between items-center mb-2">
            <label class="block text-[10px] font-semibold tracking-[0.2em] uppercase" style="color:#9CA3AF">Contraseña</label>
            <a href="/forgot-password" class="text-[10px] transition" style="color:#9CA3AF" onmouseover="this.style.color='#E5531C'" onmouseout="this.style.color='#9CA3AF'">¿Olvidaste tu contraseña?</a>
          </div>
          <input type="password" name="password" placeholder="••••••••" required
            class="w-full rounded-xl px-4 py-3 text-sm transition"
            style="border:1px solid #DDCCE6;background:#CCE2ED22;color:#000"/>
        </div>

        <!--Errores y mensajes-->
      <% if(errorL){ %>
        <h3 id="error" style="color: red;">
          <%= errorL.mensaje %>
        </h3>
        <% } %>

          <% if(mensaje){ %>
            <h3 class="text-green-300 font-semibold text-center">
              <%= mensaje %>
            </h3>
            <% } %>



        <button type="submit" class="btn-main w-full text-white text-sm font-semibold py-3.5 rounded-xl tracking-wide mt-1">
          Entrar →
        </button>
            </form>

        <div class="relative flex items-center py-1">
          <div class="flex-grow border-t" style="border-color:#DDCCE6"></div>
          <div class="flex-grow border-t" style="border-color:#DDCCE6"></div>
        </div>

      </div>

     

  <script>
    // Mascota toggle
    function setMascot(type) {
      document.getElementById('svgCat').style.display = type==='cat' ? 'block' : 'none';
      document.getElementById('svgDog').style.display = type==='dog' ? 'block' : 'none';
      document.getElementById('tagline').innerHTML = type==='cat'
        ? '"Los gatos no necesitan motivo<br>para quererte."'
        : '"Un perro te espera siempre.<br>Nosotros también."';
      ['cat','dog'].forEach(t => {
        const btn = document.getElementById('btn'+t[0].toUpperCase()+t.slice(1));
        if (t===type) {
          btn.style.background='#E5531C'; btn.style.color='white';
        } else {
          btn.style.background='transparent'; btn.style.color='black';
        }
      });
    }

    // Tab switch
    function switchTab(tab) {
      const isLogin = tab==='login';
      document.getElementById('viewLogin').classList.toggle('hidden', !isLogin);
      document.getElementById('viewRegister').classList.toggle('hidden', isLogin);
      const base = ' pb-2 text-sm font-semibold tracking-wide transition-all';
      document.getElementById('tabLogin').className   = (isLogin  ? 'tab-active' : 'tab-inactive') + base;
      document.getElementById('tabRegister').className = (!isLogin ? 'tab-active' : 'tab-inactive') + base;
    }
  </script>
</body>
</html>
