<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inicio</title>
    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body>

    <% if (userData) { %>

          <aside class="w-64 h-screen fixed left-0 top-0 bg-gray-900 text-white flex flex-col p-4">
                <h2 class="text-xl font-bold mb-6">PawLink</h2>

                <nav class="flex flex-col gap-3">

                    <a href="/index" class="px-3 py-2 rounded-lg transition
           <%= active === 'inicio' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Inicio
                    </a>

                    <a href="/#" class="px-3 py-2 rounded-lg transition
           <%= active === 'adopciones' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Adopciones
                    </a>

                    <a href="/perfil" class="px-3 py-2 rounded-lg transition
           <%= active === 'perfil' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Perfil
                    </a>

                    <a href="/#" class="px-3 py-2 rounded-lg transition
           <%= active === 'procesos' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Procesos
                    </a>

                    <a href="/contacto" class="px-3 py-2 rounded-lg transition
           <%= active === 'contacto' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                        Contacto
                    </a>

                    <%if(userData.admin) {%>
                        <a href="/adm" class="px-3 py-2 rounded-lg transition
           <%= active === 'administracion' ? 'bg-gray-700 font-semibold' : 'hover:bg-gray-700' %>">
                            Administración
                        </a>

                        <%}%>

                            <a href="/logout"
                                class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 transition mt-auto">
                                Cerrar sesión
                            </a>

                </nav>
            </aside>

            <main class="ml-64 p-6">
        <h1 class="text-xl font-bold">Bienvenido <%=userData.nombre%>
        </h1>
        <%if(userData.admin) { %>
            <h1 class="text-xl font-bold">Eres admin</h1>
            <%}%>
                <br>
                <a href="/perfil"
                    class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition font-medium">
                    Ir a perfil
                </a>

            </main>

                <%}else{%>

 <div
                class="w-full max-w-lg mx-auto mt-16 bg-white shadow-lg rounded-xl p-8 text-center border border-gray-200">
                <h2 class="text-2xl font-bold text-gray-800 mb-3">
                    ¡Ups! Parece que no estás logueado
                </h2>

                <p class="text-gray-600 mb-6">
                    Para acceder a esta sección necesitas iniciar sesión.
                    No te preocupes, te llevamos de vuelta a la página principal.
                </p>

                <a href="/"
                    class="inline-block bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:bg-blue-700 transition">
                    Volver al inicio
                </a>
            </div>
                    <%}%>

</body>

</html>